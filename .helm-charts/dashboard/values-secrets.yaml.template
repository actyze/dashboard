# Secrets Configuration Template - DO NOT COMMIT ACTUAL SECRETS TO GIT
# Copy this file to values-secrets.yaml and fill in your actual secrets
# values-secrets.yaml is in .gitignore and will not be committed

# ============================================================================
# SECRETS - Fill in your actual values
# ============================================================================
secrets:
  create: true  # Create secrets from values
  
  # AI Provider Configuration (LiteLLM Integration)
  # Choose ONE provider and add its API key, OR use Enterprise Gateway
  externalLLM:
    # Direct Connection - Add API key for your chosen provider:
    apiKey: "YOUR_API_KEY_HERE"        # For Anthropic (recommended)
    # openaiApiKey: "YOUR_OPENAI_KEY"  # For OpenAI
    # geminiApiKey: "YOUR_GEMINI_KEY"  # For Google Gemini
    # groqApiKey: "YOUR_GROQ_KEY"      # For Groq
    # perplexityApiKey: "YOUR_PPLX_KEY" # For Perplexity
    
    # AWS Bedrock (requires AWS credentials)
    # awsAccessKeyId: "YOUR_AWS_KEY"
    # awsSecretAccessKey: "YOUR_AWS_SECRET"
    # awsRegion: "us-east-1"
    
    # Get API keys from:
    # - Anthropic: https://console.anthropic.com/settings/keys
    # - OpenAI: https://platform.openai.com/api-keys
    # - Google: https://makersuite.google.com/app/apikey
    # - Groq: https://console.groq.com/keys (Free tier available)
    # - Perplexity: https://www.perplexity.ai/settings/api
    
  # Trino credentials
  trino:
    username: "admin"
    password: ""  # Leave empty for no authentication or set your Trino password
    
  # PostgreSQL database credentials
  postgres:
    username: "nexus_service"
    password: "CHANGE_ME_STRONG_PASSWORD"  # Generate strong password (min 16 chars, mixed case, numbers, symbols)

# ============================================================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# ============================================================================
# Override Trino connection details for your environment

nexus:
  env:
    trino:
      host: "dashboard-trino"           # Change to your Trino cluster hostname
      port: 8080                        # Change to your Trino port (443 for HTTPS, 8080 for HTTP)
      catalog: "postgres"               # Change to your default catalog
      schema: "demo_ecommerce"          # Change to your default schema
      ssl: false                        # Set to true for production HTTPS connections
      sslVerify: false                  # Set to false for self-signed certificates (ignored when ssl: false)

schemaService:
  env:
    trino:
      host: "dashboard-trino"           # Should match nexus.env.trino.host
      port: 8080                        # Should match nexus.env.trino.port
      catalog: "postgres"               # Schema service will discover all schemas
      schema: "demo_ecommerce"          # Default schema (optional)
      ssl: false                        # Should match nexus.env.trino.ssl
      sslVerify: false                  # Should match nexus.env.trino.sslVerify (ignored when ssl: false)

# ============================================================================
# EXTERNAL TRINO CONFIGURATION EXAMPLE
# ============================================================================
# If using an external Trino cluster (not the included one), configure:
#
# nexus:
#   env:
#     trino:
#       host: "your-trino-cluster.company.com"
#       port: 443
#       catalog: "your_catalog"
#       schema: "your_schema"
#       ssl: true
#       sslVerify: false  # Set to false for self-signed certificates
#
# schemaService:
#   env:
#     trino:
#       host: "your-trino-cluster.company.com"
#       port: 443
#       catalog: "your_catalog"
#       schema: "your_schema"
#       ssl: true
#       sslVerify: false  # Set to false for self-signed certificates
#
# And disable the included Trino service:
# services:
#   trino:
#     enabled: false
# ============================================================================

