# Dashboard Local Development Environment Variables
# Copy this file to .env and fill in your actual values
# .env file is in .gitignore and will not be committed

# External LLM API Key (Required for SQL generation)
# Get your API key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# Alternative LLM Providers (uncomment to use)
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# GROQ_API_KEY=your-groq-api-key-here

# Database Credentials (Optional - defaults are provided)
# POSTGRES_USER=nexus_service
# POSTGRES_PASSWORD=secure_dev_password
# POSTGRES_DB=dashboard

# Development Settings (Optional)
# DEBUG=true
# LOG_LEVEL=INFO
