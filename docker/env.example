# Dashboard Local Development Environment Variables
# Copy this file to .env and fill in your actual values
# .env file is in .gitignore and will not be committed

# ============================================================================
# EXTERNAL LLM CONFIGURATION - Required for SQL generation
# ============================================================================
# Get your API key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=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

# Alternative LLM Providers (uncomment to use instead of Perplexity)
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# GROQ_API_KEY=your-groq-api-key-here

# ============================================================================
# DATABASE CREDENTIALS - PostgreSQL Configuration
# ============================================================================
POSTGRES_USER=nexus_service
POSTGRES_PASSWORD=PostgreActyze123$
POSTGRES_DB=dashboard

# ============================================================================
# TRINO CONFIGURATION - Query Engine Settings
# ============================================================================
TRINO_HOST=dashboard-trino
TRINO_PORT=8080
TRINO_USER=admin
TRINO_PASSWORD=
TRINO_CATALOG=postgres
TRINO_SCHEMA=demo_ecommerce
TRINO_SSL=false

# ============================================================================
# SERVICE CONFIGURATION - Development Settings
# ============================================================================
# Nexus Service Settings
DEBUG=true
LOG_LEVEL=INFO

# Schema Service Settings
SCHEMA_SERVICE_HOST=schema-service
SCHEMA_SERVICE_PORT=8000

# Cache Configuration
CACHE_ENABLED=true
CACHE_QUERY_MAX_SIZE=100
CACHE_QUERY_TTL=1800

# ============================================================================
# EXTERNAL LLM PROVIDER SETTINGS
# ============================================================================
EXTERNAL_LLM_ENABLED=true
EXTERNAL_LLM_PROVIDER=perplexity
EXTERNAL_LLM_BASE_URL=https://api.perplexity.ai/chat/completions
EXTERNAL_LLM_MODEL=sonar-reasoning-pro
EXTERNAL_LLM_MAX_TOKENS=1000
EXTERNAL_LLM_TEMPERATURE=0.1
