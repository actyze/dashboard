# Dashboard Local Development Environment Variables
# Copy this file to .env and fill in your actual values
# .env file is in .gitignore and will not be committed

# ============================================================================
# AI PROVIDER CONFIGURATION - Choose Your AI Service
# ============================================================================
# Actyze works with 100+ AI providers. Just add your API key and model name.
# See: dashboard-docker/LLM_PROVIDERS.md for full provider list

# -------------------------
# DIRECT CONNECTION (Recommended)
# -------------------------
# Connect directly to any major AI provider
# Setup: Just 2 lines - API key + model name

# Anthropic Claude (Recommended)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
EXTERNAL_LLM_MODEL=claude-sonnet-4-20250514

# OR OpenAI
# OPENAI_API_KEY=your-openai-api-key-here
# EXTERNAL_LLM_MODEL=gpt-4o

# OR Google Gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# EXTERNAL_LLM_MODEL=gemini/gemini-pro

# OR Groq (Free tier available)
# GROQ_API_KEY=your-groq-api-key-here
# EXTERNAL_LLM_MODEL=groq/llama-3.3-70b-versatile

# OR Perplexity
# PERPLEXITY_API_KEY=your-perplexity-api-key-here
# EXTERNAL_LLM_MODEL=perplexity/sonar-reasoning-pro

# -------------------------
# ENTERPRISE GATEWAY (Optional)
# -------------------------
# For IT-managed AI access through your company gateway
# EXTERNAL_LLM_MODE=openai-compatible
# EXTERNAL_LLM_BASE_URL=https://llm-gateway.company.com/v1/chat/completions
# EXTERNAL_LLM_MODEL=your-internal-model
# EXTERNAL_LLM_API_KEY=your-enterprise-token
# EXTERNAL_LLM_AUTH_TYPE=bearer
# EXTERNAL_LLM_EXTRA_HEADERS={"X-Department": "engineering"}

# -------------------------
# Common AI Settings
# -------------------------
EXTERNAL_LLM_ENABLED=true
EXTERNAL_LLM_MAX_TOKENS=4096
EXTERNAL_LLM_TEMPERATURE=0.1

# ============================================================================
# DATABASE CREDENTIALS - PostgreSQL Configuration
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dashboard
POSTGRES_USER=nexus_service
POSTGRES_PASSWORD=your-secure-password-here

# For external PostgreSQL (uncomment and modify):
# POSTGRES_HOST=your-external-postgres-host
# POSTGRES_PORT=5432
# POSTGRES_DB=your-database-name
# POSTGRES_USER=your-database-user
# POSTGRES_PASSWORD=your-secure-password

# ============================================================================
# TRINO CONFIGURATION - Query Engine Settings
# ============================================================================
# For local Trino (default):
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_USER=admin
TRINO_PASSWORD=
TRINO_CATALOG=postgres
TRINO_SCHEMA=public
TRINO_SSL=false

# For external Trino (uncomment and modify):
# TRINO_HOST=your-external-trino-host
# TRINO_PORT=443
# TRINO_USER=your-trino-username
# TRINO_PASSWORD=your-trino-password
# TRINO_CATALOG=your-catalog
# TRINO_SCHEMA=your-schema
# TRINO_SSL=true
# 
# Exclude problematic catalogs (comma-separated list)
# Useful for external Trino instances with catalogs that have connection issues
# Example: EXCLUDED_CATALOGS=och,problematic_catalog
# EXCLUDED_CATALOGS=

# ============================================================================
# EXTERNAL DATA SOURCES - Trino Catalogs
# ============================================================================
# Configure additional data source connections for Trino
# These are optional - uncomment and configure as needed

# MongoDB Atlas
# Example: mongodb+srv://username:password@cluster0.mongodb.net/?appName=Cluster0
# MONGODB_CONNECTION_URL=mongodb+srv://nexus_service:YourPassword@cluster0.mongodb.net/?appName=YourApp

# Snowflake Data Warehouse
# Example: jdbc:snowflake://account.snowflakecomputing.com/?warehouse=WH_NAME&db=DB_NAME&role=ROLE_NAME
# SNOWFLAKE_CONNECTION_URL=jdbc:snowflake://account.snowflakecomputing.com/?warehouse=COMPUTE_WH&db=DATABASE&role=ACCOUNTADMIN
# SNOWFLAKE_USER=your-snowflake-username
# SNOWFLAKE_PASSWORD=your-snowflake-password

# ============================================================================
# SERVICE CONFIGURATION - Development Settings
# ============================================================================
# Nexus Service Settings
DEBUG=true
LOG_LEVEL=INFO

# Schema Service Settings
SCHEMA_SERVICE_HOST=schema-service
SCHEMA_SERVICE_PORT=8000

# Service-to-Service Authentication
# Simple shared secret for internal service communication (Nexus <-> Schema Service)
# Generate a strong random key for production (32+ characters)
SCHEMA_SERVICE_KEY=dev-secret-key-change-in-production

# Cache Configuration
CACHE_ENABLED=true
CACHE_QUERY_MAX_SIZE=100
CACHE_QUERY_TTL=1800

# ============================================================================
# PREFERRED TABLES CONFIGURATION
# ============================================================================
# Maximum number of tables a user can mark as preferred
# Preferred tables are prioritized by AI when generating SQL queries
# Default: 50 (recommended range: 20-100)
MAX_PREFERRED_TABLES=50


