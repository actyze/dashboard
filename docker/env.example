# Dashboard Local Development Environment Variables
# Copy this file to .env and fill in your actual values
# .env file is in .gitignore and will not be committed

# ============================================================================
# EXTERNAL LLM CONFIGURATION - Required for SQL generation
# ============================================================================
# Actyze supports ANY LLM provider with flexible authentication
# Configure API key, auth type, and extra headers based on your provider

# DEFAULT: Perplexity (Bearer token authentication)
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# ALTERNATIVE PROVIDERS - See examples below:
# OpenAI: OPENAI_API_KEY=your-openai-api-key-here
# Anthropic Claude: ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Groq: GROQ_API_KEY=your-groq-api-key-here

# ============================================================================
# DATABASE CREDENTIALS - PostgreSQL Configuration
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dashboard
POSTGRES_USER=nexus_service
POSTGRES_PASSWORD=your-secure-password-here

# For external PostgreSQL (uncomment and modify):
# POSTGRES_HOST=your-external-postgres-host
# POSTGRES_PORT=5432
# POSTGRES_DB=your-database-name
# POSTGRES_USER=your-database-user
# POSTGRES_PASSWORD=your-secure-password
# POSTGRES_USER=your-username
# POSTGRES_PASSWORD=your-password

# ============================================================================
# TRINO CONFIGURATION - Query Engine Settings
# ============================================================================
# For local Trino (default):
TRINO_HOST=dashboard-trino
TRINO_PORT=8080
TRINO_USER=admin
TRINO_PASSWORD=
TRINO_CATALOG=postgres
TRINO_SCHEMA=demo_ecommerce
TRINO_SSL=false

# For external Trino (uncomment and modify):
# TRINO_HOST=your-external-trino-host
# TRINO_PORT=443
# TRINO_USER=your-trino-username
# TRINO_PASSWORD=your-trino-password
# TRINO_CATALOG=your-catalog
# TRINO_SCHEMA=your-schema
# TRINO_SSL=true

# ============================================================================
# SERVICE CONFIGURATION - Development Settings
# ============================================================================
# Nexus Service Settings
DEBUG=true
LOG_LEVEL=INFO

# Schema Service Settings
SCHEMA_SERVICE_HOST=schema-service
SCHEMA_SERVICE_PORT=8000

# Service-to-Service Authentication
# Simple shared secret for internal service communication (Nexus <-> Schema Service)
# Generate a strong random key for production (32+ characters)
SCHEMA_SERVICE_KEY=dev-secret-key-change-in-production

# Cache Configuration
CACHE_ENABLED=true
CACHE_QUERY_MAX_SIZE=100
CACHE_QUERY_TTL=1800

# ============================================================================
# EXTERNAL LLM PROVIDER SETTINGS - Flexible Configuration
# ============================================================================
EXTERNAL_LLM_ENABLED=true

# -------------------------
# OPTION 1: Perplexity (Default)
# -------------------------
EXTERNAL_LLM_PROVIDER=perplexity
EXTERNAL_LLM_BASE_URL=https://api.perplexity.ai/chat/completions
EXTERNAL_LLM_MODEL=sonar-reasoning-pro
EXTERNAL_LLM_AUTH_TYPE=bearer
EXTERNAL_LLM_EXTRA_HEADERS=

# -------------------------
# OPTION 2: Anthropic Claude
# -------------------------
# EXTERNAL_LLM_PROVIDER=anthropic
# EXTERNAL_LLM_BASE_URL=https://api.anthropic.com/v1/messages
# EXTERNAL_LLM_MODEL=claude-sonnet-4-20250514
# EXTERNAL_LLM_AUTH_TYPE=x-api-key
# EXTERNAL_LLM_EXTRA_HEADERS={"anthropic-version": "2023-06-01"}
# PERPLEXITY_API_KEY=${ANTHROPIC_API_KEY}  # Reuse API key variable

# -------------------------
# OPTION 3: OpenAI
# -------------------------
# EXTERNAL_LLM_PROVIDER=openai
# EXTERNAL_LLM_BASE_URL=https://api.openai.com/v1/chat/completions
# EXTERNAL_LLM_MODEL=gpt-4o
# EXTERNAL_LLM_AUTH_TYPE=bearer
# EXTERNAL_LLM_EXTRA_HEADERS=
# PERPLEXITY_API_KEY=${OPENAI_API_KEY}  # Reuse API key variable

# -------------------------
# OPTION 4: Groq
# -------------------------
# EXTERNAL_LLM_PROVIDER=groq
# EXTERNAL_LLM_BASE_URL=https://api.groq.com/openai/v1/chat/completions
# EXTERNAL_LLM_MODEL=llama-3.3-70b-versatile
# EXTERNAL_LLM_AUTH_TYPE=bearer
# EXTERNAL_LLM_EXTRA_HEADERS=
# PERPLEXITY_API_KEY=${GROQ_API_KEY}  # Reuse API key variable

# Common LLM Settings (applies to all providers)
EXTERNAL_LLM_MAX_TOKENS=4096
EXTERNAL_LLM_TEMPERATURE=0.1

# -------------------------
# Authentication Types Reference:
# -------------------------
# - "bearer": OpenAI, Perplexity, Groq, Together AI (Authorization: Bearer TOKEN)
# - "x-api-key": Anthropic Claude (x-api-key: TOKEN)
# - "api-key": Azure OpenAI (api-key: TOKEN)
#
# Extra Headers: JSON string for provider-specific headers
# Example: {"anthropic-version": "2023-06-01"} for Claude
