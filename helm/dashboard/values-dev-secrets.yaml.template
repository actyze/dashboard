# Development Secrets Template
# Copy this file to values-dev-secrets.yaml and fill in your actual secrets
# values-dev-secrets.yaml is in .gitignore and will not be committed

# ============================================================================
# DEVELOPMENT SECRETS TEMPLATE - REPLACE WITH YOUR CREDENTIALS
# ============================================================================
secrets:
  create: true  # Create secrets from values for development convenience
  
  # External LLM configuration
  externalLLM:
    apiKey: "your-perplexity-api-key-here"  # Get from https://www.perplexity.ai/settings/api
    
  # Trino credentials
  trino:
    username: "your-trino-username"  # Your Trino username
    password: "your-trino-password"  # Your Trino password
    
  # PostgreSQL database credentials (optional - defaults work for local demo)
  postgres:
    username: "dashboard_user"
    password: "dashboard_password"

# ============================================================================
# DEVELOPMENT OVERRIDES - REQUIRED FOR TRINO CONNECTION
# ============================================================================
# Override Trino connection details (REQUIRED)
backend:
  env:
    trino:
      host: "your-trino-cluster.company.com"  # Replace with your Trino host
      port: 443
      catalog: "your_catalog"  # Replace with your catalog
      schema: "your_schema"    # Replace with your schema
      ssl: false  # Important: disable SSL for local development

schemaService:
  env:
    trino:
      host: "your-trino-cluster.company.com"  # Replace with your Trino host
      port: 443
      catalog: "your_catalog"  # Replace with your catalog
      schema: "your_schema"    # Replace with your schema
      ssl: false  # Important: disable SSL for local development
