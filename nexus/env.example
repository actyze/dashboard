# Nexus Environment Configuration

# Service Configuration
NEXUS_HOST=0.0.0.0
NEXUS_PORT=8002
DEBUG=false

# PostgreSQL Configuration (for user data)
POSTGRES_HOST=dashboard-postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=dashboard
POSTGRES_USER=dashboard_user
POSTGRES_PASSWORD=dashboard_password

# Redis Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

# External Services
SCHEMA_SERVICE_URL=http://dashboard-schema-service:8001
LLM_SERVICE_URL=http://dashboard-fastapi:8000
TRINO_HOST=dashboard-trino
TRINO_PORT=8080
TRINO_CATALOG=postgres
TRINO_SCHEMA=public
TRINO_USER=admin
TRINO_PASSWORD=

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=1.0
RETRY_BACKOFF=2.0

# Query Configuration
DEFAULT_MAX_RESULTS=100
DEFAULT_TIMEOUT_SECONDS=30
CONVERSATION_HISTORY_SIZE=5

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=5.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
