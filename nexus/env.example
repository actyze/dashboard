# =============================================================================
# Nexus Service Configuration
# =============================================================================
# This configuration mirrors the Helm-driven approach used in the Java backend
# All values should be provided via Helm charts in production environments
# =============================================================================

# =============================================================================
# Service Configuration
# =============================================================================
NEXUS_HOST=${NEXUS_HOST:0.0.0.0}
NEXUS_PORT=${NEXUS_PORT:8002}
DEBUG=${DEBUG:false}

# =============================================================================
# Database Configuration - PostgreSQL (User Data Persistence)
# =============================================================================
POSTGRES_HOST=${POSTGRES_HOST:dashboard-postgres}
POSTGRES_PORT=${POSTGRES_PORT:5432}
POSTGRES_DATABASE=${POSTGRES_DATABASE:dashboard}
POSTGRES_USER=${POSTGRES_USER:dashboard_user}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:dashboard_password}
POSTGRES_SSL_MODE=${POSTGRES_SSL_MODE:prefer}
POSTGRES_POOL_SIZE=${POSTGRES_POOL_SIZE:20}
POSTGRES_MAX_OVERFLOW=${POSTGRES_MAX_OVERFLOW:30}
POSTGRES_POOL_TIMEOUT=${POSTGRES_POOL_TIMEOUT:30}

# =============================================================================
# Cache Configuration - Redis or Memory
# =============================================================================
CACHE_TYPE=${CACHE_TYPE:memory}  # "memory" or "redis"
CACHE_ENABLED=${CACHE_ENABLED:true}
CACHE_TTL=${CACHE_TTL:300}
CACHE_KEY_PREFIX=${CACHE_KEY_PREFIX:nexus:}
CACHE_STATS_LOG_INTERVAL=${CACHE_STATS_LOG_INTERVAL:300}

# Redis Configuration (only if CACHE_TYPE=redis)
REDIS_URL=${REDIS_URL:redis://dashboard-redis:6379}
REDIS_PASSWORD=${REDIS_PASSWORD:}
REDIS_DB=${REDIS_DB:0}
REDIS_SSL=${REDIS_SSL:false}
REDIS_POOL_SIZE=${REDIS_POOL_SIZE:10}

# Memory Cache Configuration (only if CACHE_TYPE=memory)
CACHE_QUERY_MAX_SIZE=${CACHE_QUERY_MAX_SIZE:1000}
CACHE_METADATA_MAX_SIZE=${CACHE_METADATA_MAX_SIZE:200}
CACHE_LONGTERM_MAX_SIZE=${CACHE_LONGTERM_MAX_SIZE:100}
CACHE_SCHEMA_MAX_SIZE=${CACHE_SCHEMA_MAX_SIZE:500}
CACHE_LLM_MAX_SIZE=${CACHE_LLM_MAX_SIZE:200}
CACHE_METADATA_TTL=${CACHE_METADATA_TTL:600}
CACHE_LONGTERM_TTL=${CACHE_LONGTERM_TTL:3600}
CACHE_SCHEMA_TTL=${CACHE_SCHEMA_TTL:1800}
CACHE_LLM_TTL=${CACHE_LLM_TTL:7200}

# =============================================================================
# External Services Configuration
# =============================================================================

# FAISS Schema Service Configuration
SCHEMA_SERVICE_URL=${SCHEMA_SERVICE_URL:http://dashboard-schema-service:8001}
SCHEMA_SERVICE_TIMEOUT=${SCHEMA_SERVICE_TIMEOUT:30}
SCHEMA_SERVICE_RETRIES=${SCHEMA_SERVICE_RETRIES:3}
SCHEMA_SERVICE_RETRY_DELAY=${SCHEMA_SERVICE_RETRY_DELAY:1.0}

# ML/LLM Service Configuration
LLM_SERVICE_URL=${LLM_SERVICE_URL:http://dashboard-fastapi:8000}
LLM_SERVICE_TIMEOUT=${LLM_SERVICE_TIMEOUT:30}
LLM_SERVICE_RETRIES=${LLM_SERVICE_RETRIES:2}
LLM_SERVICE_READ_TIMEOUT=${LLM_SERVICE_READ_TIMEOUT:15}

# LLM Model Parameters
LLM_MAX_TOKENS=${LLM_MAX_TOKENS:1000}
LLM_TEMPERATURE=${LLM_TEMPERATURE:0.1}
LLM_MAX_LENGTH=${LLM_MAX_LENGTH:4096}
LLM_DO_SAMPLE=${LLM_DO_SAMPLE:false}
LLM_NUM_BEAMS=${LLM_NUM_BEAMS:1}

# External LLM Configuration (OpenAI, Perplexity, etc.)
EXTERNAL_LLM_ENABLED=${EXTERNAL_LLM_ENABLED:false}
EXTERNAL_LLM_PROVIDER=${EXTERNAL_LLM_PROVIDER:}
EXTERNAL_LLM_API_KEY=${EXTERNAL_LLM_API_KEY:}
EXTERNAL_LLM_MODEL=${EXTERNAL_LLM_MODEL:}
EXTERNAL_LLM_BASE_URL=${EXTERNAL_LLM_BASE_URL:}
EXTERNAL_LLM_MAX_TOKENS=${EXTERNAL_LLM_MAX_TOKENS:4096}
EXTERNAL_LLM_TEMPERATURE=${EXTERNAL_LLM_TEMPERATURE:0.1}
EXTERNAL_LLM_TIMEOUT=${EXTERNAL_LLM_TIMEOUT:30}

# =============================================================================
# Trino Database Configuration
# =============================================================================
TRINO_HOST=${TRINO_HOST:dashboard-trino}
TRINO_PORT=${TRINO_PORT:8080}
TRINO_USER=${TRINO_USER:admin}
TRINO_PASSWORD=${TRINO_PASSWORD:}
TRINO_CATALOG=${TRINO_CATALOG:postgres}
TRINO_SCHEMA=${TRINO_SCHEMA:public}
TRINO_SSL=${TRINO_SSL:false}
TRINO_MAX_ROWS=${TRINO_MAX_ROWS:1000}
TRINO_QUERY_TIMEOUT_SECONDS=${TRINO_QUERY_TIMEOUT_SECONDS:300}

# =============================================================================
# Query Processing Configuration
# =============================================================================
DEFAULT_MAX_RESULTS=${DEFAULT_MAX_RESULTS:100}
DEFAULT_TIMEOUT_SECONDS=${DEFAULT_TIMEOUT_SECONDS:30}
MAX_QUERY_LENGTH=${MAX_QUERY_LENGTH:10000}
MAX_RESULT_ROWS=${MAX_RESULT_ROWS:1000}
CONVERSATION_HISTORY_SIZE=${CONVERSATION_HISTORY_SIZE:5}

# =============================================================================
# Retry and Resilience Configuration
# =============================================================================
MAX_RETRIES=${MAX_RETRIES:3}
RETRY_DELAY=${RETRY_DELAY:1.0}
RETRY_BACKOFF=${RETRY_BACKOFF:2.0}
CIRCUIT_BREAKER_ENABLED=${CIRCUIT_BREAKER_ENABLED:true}
CIRCUIT_BREAKER_FAILURE_THRESHOLD=${CIRCUIT_BREAKER_FAILURE_THRESHOLD:5}
CIRCUIT_BREAKER_TIMEOUT=${CIRCUIT_BREAKER_TIMEOUT:60}

# =============================================================================
# Health Check Configuration
# =============================================================================
HEALTH_CHECK_TIMEOUT=${HEALTH_CHECK_TIMEOUT:5.0}
HEALTH_CHECK_INTERVAL=${HEALTH_CHECK_INTERVAL:30}
HEALTH_CHECK_ENABLED=${HEALTH_CHECK_ENABLED:true}

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=${LOG_LEVEL:INFO}
LOG_FORMAT=${LOG_FORMAT:json}
LOG_FILE=${LOG_FILE:}
LOG_MAX_SIZE=${LOG_MAX_SIZE:100MB}
LOG_BACKUP_COUNT=${LOG_BACKUP_COUNT:5}

# Specific logger levels
LOG_LEVEL_NEXUS=${LOG_LEVEL_NEXUS:INFO}
LOG_LEVEL_ORCHESTRATION=${LOG_LEVEL_ORCHESTRATION:INFO}
LOG_LEVEL_DATABASE=${LOG_LEVEL_DATABASE:WARN}
LOG_LEVEL_CACHE=${LOG_LEVEL_CACHE:WARN}
LOG_LEVEL_HTTP=${LOG_LEVEL_HTTP:WARN}

# =============================================================================
# Security Configuration
# =============================================================================
SECRET_KEY=${SECRET_KEY:}
JWT_SECRET=${JWT_SECRET:}
JWT_EXPIRATION=${JWT_EXPIRATION:3600}
CORS_ORIGINS=${CORS_ORIGINS:*}
CORS_CREDENTIALS=${CORS_CREDENTIALS:true}
RATE_LIMIT_ENABLED=${RATE_LIMIT_ENABLED:false}
RATE_LIMIT_REQUESTS=${RATE_LIMIT_REQUESTS:100}
RATE_LIMIT_WINDOW=${RATE_LIMIT_WINDOW:60}

# =============================================================================
# Monitoring and Observability
# =============================================================================
METRICS_ENABLED=${METRICS_ENABLED:true}
METRICS_PORT=${METRICS_PORT:9090}
PROMETHEUS_ENABLED=${PROMETHEUS_ENABLED:false}
JAEGER_ENABLED=${JAEGER_ENABLED:false}
JAEGER_ENDPOINT=${JAEGER_ENDPOINT:}

# =============================================================================
# Development and Testing Configuration
# =============================================================================
TESTING_MODE=${TESTING_MODE:false}
MOCK_EXTERNAL_SERVICES=${MOCK_EXTERNAL_SERVICES:false}
ENABLE_GRAPHQL_PLAYGROUND=${ENABLE_GRAPHQL_PLAYGROUND:true}
ENABLE_SWAGGER_UI=${ENABLE_SWAGGER_UI:true}

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_USER_MANAGEMENT=${FEATURE_USER_MANAGEMENT:true}
FEATURE_CONVERSATION_HISTORY=${FEATURE_CONVERSATION_HISTORY:true}
FEATURE_QUERY_CACHING=${FEATURE_QUERY_CACHING:true}
FEATURE_SCHEMA_RECOMMENDATIONS=${FEATURE_SCHEMA_RECOMMENDATIONS:true}
FEATURE_SQL_CORRECTION=${FEATURE_SQL_CORRECTION:true}
